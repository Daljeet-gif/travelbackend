# ─── Server ───────────────────────────────────────────────
PORT=5000
NODE_ENV=development
# Comma-separated list of allowed frontend origins
FRONTEND_URL=http://localhost:3000

# ─── Database ─────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/tripgenie

# ─── Auth ─────────────────────────────────────────────────
JWT_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret

# ─── Third-party APIs ─────────────────────────────────────
# Geoapify: geocoding, places AND routing (budget estimate)
GEOAPIFY_API_KEY=your_geoapify_key
# WeatherAPI.com forecast
WEATHER_API_KEY=your_weatherapi_key
# Groq (LLM) — itinerary, chat, packing list, local info
GROQ_API_KEY=your_groq_key
